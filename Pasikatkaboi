-- [[ ANIMATION NG ILAW (GLOW) ]] --
local function startGlowAnimation()
    local tweenInfo = TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
    
    -- Ang border ay mag-re-red at magdidilim (pulsing effect)
    TweenService:Create(UIStroke, tweenInfo, {Color = Color3.fromRGB(80, 0, 0)}):Play()
    
    -- Ang Title text ay sasabay din sa ilaw
    TweenService:Create(Title, tweenInfo, {TextColor3 = Color3.fromRGB(180, 0, 0)}):Play()
end
startGlowAnimation()

-- BUTTON LOGICS
GetKeyBtn.MouseButton1Click:Connect(function()
    GetKeyBtn.Text = "REDIRECTING..."
    if setclipboard then setclipboard(fbLink) end
    pcall(function() GuiService:OpenBrowserWindow(fbLink) end)
    wait(2)
    GetKeyBtn.Text = "GO TO FACEBOOK"
end)

MainBtn.MouseButton1Click:Connect(function()
    if TextBox.Text == KEY then
        MainBtn.Text = "SUCCESS!"
        wait(0.5)
        ScreenGui:Destroy()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/dezqpal/Primo/refs/heads/main/CeyyOBFUSCATED.LUA"))()
        end)
    else
        TextBox.Text = ""
        MainBtn.Text = "INVALID KEY!"
        wait(1.5)
        MainBtn.Text = "SUBMIT"
    end
end)
