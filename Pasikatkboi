-- GLOW ANIMATION
local function createGlow()
    local info = TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
    TweenService:Create(UIStroke, info, {Color = Color3.fromRGB(50, 0, 0)}):Play()
    TweenService:Create(Title, info, {TextColor3 = Color3.fromRGB(150, 0, 0)}):Play()
end
createGlow()

-- BUTTON LOGICS
GetKeyBtn.MouseButton1Click:Connect(function()
    if setclipboard then
        setclipboard(fbLink)
        GetKeyBtn.Text = "FB LINK COPIED!"
    else
        GetKeyBtn.Text = "ERROR: NO CLIPBOARD"
    end
    wait(2)
    GetKeyBtn.Text = "GET KEY (FACEBOOK)"
end)

MainBtn.MouseButton1Click:Connect(function()
    if TextBox.Text == KEY then
        MainBtn.Text = "SUCCESS!"
        wait(0.5)
        ScreenGui:Destroy()
        -- Maglo-load ang main script mo
        local success, err = pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/dezqpal/Primo/refs/heads/main/CeyyOBFUSCATED.LUA"))()
        end)
        if not success then
            warn("Failed to load script: " .. tostring(err))
        end
    else
        TextBox.Text = ""
        MainBtn.Text = "INVALID KEY!"
        wait(1.5)
        MainBtn.Text = "SUBMIT"
    end
end)
